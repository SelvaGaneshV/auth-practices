    "zod": "catalog:"
  },
  "devDependencies": {
    "@auth-practices/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
