{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@auth-practices/api": "workspace:*",
    "@auth-practices/db": "workspace:*",
    "@auth-practices/env": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "drizzle-orm": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@auth-practices/config": "workspace:*",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}