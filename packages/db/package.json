{
  "name": "@auth-practices/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./schema/index": {
      "types": "./dist/schema/index.d.mts",
      "default": "./dist/schema/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "db:local": "turso dev --db-file local.db",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@auth-practices/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auth-practices/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  }
}
