{
  "name": "@auth-practices/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "node -e \"console.log('Local SQLite: set DATABASE_URL=file:local.db and DATABASE_AUTH_TOKEN= in apps/server/.env, then run pnpm db:migrate')\"",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@auth-practices/env": "workspace:*",
    "@libsql/client": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@auth-practices/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}